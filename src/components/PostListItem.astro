---
interface Props {
  title: string;
  description: string;
  href: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, href, pubDate, tags = [] } = Astro.props;
---

<article class="border-b border-black/10 py-6 last:border-b-0 dark:border-white/10">
  <p class="text-sm text-black/55 dark:text-white/55">{pubDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</p>
  <h2 class="mt-2 text-2xl font-semibold"><a href={href} class="text-ink no-underline hover:text-pine dark:text-white">{title}</a></h2>
  <p class="mt-3 text-black/70 dark:text-white/70">{description}</p>
  {tags.length > 0 && <div class="mt-4 flex flex-wrap gap-2">{tags.map((tag) => <span class="tag">{tag}</span>)}</div>}
</article>
