---
interface Props {
  title: string;
  description: string;
  href: string;
  technologies?: string[];
  placeholder?: boolean;
}

const { title, description, href, technologies = [], placeholder = false } = Astro.props;
---

<article class="panel rounded-lg">
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-xl font-semibold"><a href={href} class="text-ink no-underline hover:text-pine dark:text-white">{title}</a></h3>
    {placeholder && <span class="tag shrink-0">Placeholder</span>}
  </div>
  <p class="mt-3 text-sm leading-6 text-black/70 dark:text-white/70">{description}</p>
  {technologies.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2">
      {technologies.map((tech) => <span class="tag">{tech}</span>)}
    </div>
  )}
</article>
