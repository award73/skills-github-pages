---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import PostListItem from "@components/PostListItem.astro";
import { getCollection } from "astro:content";
import { profile, skills } from "@data/profile";
import { libraryLinks } from "@data/library";

const projects = (await getCollection("projects")).slice(0, 3);
const posts = (await getCollection("blog")).filter((post) => !post.data.draft).slice(0, 3);
---

<BaseLayout title={profile.name} description={profile.summary}>
  <section class="shell grid gap-10 py-16 md:grid-cols-[1.15fr_0.85fr] md:items-center md:py-24">
    <div>
      <p class="eyebrow">Personal site</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-normal text-ink dark:text-white md:text-6xl">{profile.name}</h1>
      <p class="mt-5 max-w-3xl text-2xl leading-tight text-black/78 dark:text-white/78">{profile.title}</p>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-black/68 dark:text-white/68">{profile.summary}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/projects" class="button">View projects</a>
        <a href="/resume" class="button-secondary">Read resume</a>
        <a href="/blog" class="button-secondary">Latest writing</a>
        <a href="/library" class="button-secondary">Browse library</a>
      </div>
    </div>
    <aside class="panel rounded-lg">
      <img src="/images/profile.jpg" alt="Andrew Ward" class="mb-6 aspect-[4/3] w-full rounded-md object-cover" />
      <p class="eyebrow">Focus areas</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {profile.focusAreas.map((area) => <span class="tag">{area}</span>)}
      </div>
      <dl class="mt-8 grid gap-5 text-sm">
        {skills.slice(0, 3).map((group) => (
          <div>
            <dt class="font-semibold text-ink dark:text-white">{group.group}</dt>
            <dd class="mt-1 text-black/65 dark:text-white/65">{group.items.join(" / ")}</dd>
          </div>
        ))}
      </dl>
    </aside>
  </section>

  <section class="shell py-10">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="eyebrow">Portfolio</p>
        <h2 class="section-title mt-3">Featured Projects</h2>
      </div>
      <a href="/projects" class="text-sm font-semibold">All projects</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {projects.map((project) => <ProjectCard title={project.data.title} description={project.data.description} href={`/projects/${project.slug}`} technologies={project.data.technologies} placeholder={project.data.placeholder} />)}
    </div>
  </section>

  <section class="shell py-10">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="eyebrow">Writing</p>
        <h2 class="section-title mt-3">Recent Posts</h2>
      </div>
      <a href="/blog" class="text-sm font-semibold">All writing</a>
    </div>
    <div class="mt-6">
      {posts.map((post) => <PostListItem title={post.data.title} description={post.data.description} href={`/blog/${post.slug}`} pubDate={post.data.pubDate} tags={post.data.tags} />)}
    </div>
  </section>

  <section class="shell py-10">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="eyebrow">Library</p>
        <h2 class="section-title mt-3">Useful Links</h2>
      </div>
      <a href="/library" class="text-sm font-semibold">Open library</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {libraryLinks.slice(0, 2).map((item) => (
        <article class="panel rounded-lg">
          <p class="tag inline-flex">{item.category}</p>
          <h3 class="mt-4 text-xl font-semibold"><a href={item.href} class="text-ink no-underline hover:text-pine dark:text-white">{item.title}</a></h3>
          <p class="mt-3 text-sm leading-6 text-black/70 dark:text-white/70">{item.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
